# Gateway Debug Configuration
# Set these environment variables to control gateway behavior

# Prevent server from shutting down on errors (default: false)
EXIT_ON_ERROR=false

# Maximum number of restart attempts before giving up (default: 100)
MAX_RESTART_ATTEMPTS=100

# Heartbeat monitoring interval in seconds (default: 30)
HEARTBEAT_INTERVAL=30

# Registry connection string
REGISTRY_PATH=redis://klone-login01.hyak.local:6379

# Server port
PORT=8080

# Number of worker processes
WORKERS=1

# Logging level
LOG_LEVEL=info

# Uvicorn specific settings
UVICORN_ACCESS_LOG=true
UVICORN_LOG_LEVEL=info
UVICORN_TIMEOUT_GRACEFUL_SHUTDOWN=60



